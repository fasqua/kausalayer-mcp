{
  "name": "@kausalayer/mcp",
  "version": "1.1.2",
  "description": "KausaLayer MCP Server - Privacy infrastructure for AI agents on Solana",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kausalayer-mcp": "./dist/index.js"
  },
  "scripts": {
